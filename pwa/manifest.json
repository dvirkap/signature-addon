{
  "name": "פשוט לחתום - Just sign",
  "short_name": "Just sign",
  "description": "תוסף לחתימה מהירה ונוחה על קובצי PDF / Quick and easy PDF signing web app.",
  "start_url": "./index.html",
  "display": "standalone",
  "background_color": "#1a1a2e",
  "theme_color": "#2c3e50",
  "orientation": "any",
  "icons": [
    {
      "src": "icons/icon128.png",
      "sizes": "128x128",
      "type": "image/png"
    },
    {
      "src": "icons/icon512.png",
      "sizes": "512x512",
      "type": "image/png"
    }
  ],
  "file_handlers": [
    {
      "action": "./index.html",
      "name": "פשוט לחתום - Just sign",
      "accept": {
        "application/pdf": [".pdf"]
      }
    }
  ]
}